# Rails: "sandbox" (default, zero credentials) or "live"
RAILS_MODE=sandbox
PORT=4000
# Public URL the rail providers can reach for webhook callbacks
PUBLIC_URL=http://localhost:4000

# --- IBEX Hub (poweredbyibex.io) — crypto inbound: Lightning + on-chain BTC ---
# OAuth2 client-credentials. Set CLIENT_ID + CLIENT_SECRET + ACCOUNT_ID together
# to activate the real crypto rail (independent of RAILS_MODE). USDT is gated
# per-organization by IBEX. URLs derive from IBEX_ENV; override only if needed.
IBEX_ENV=sandbox
IBEX_CLIENT_ID=
IBEX_CLIENT_SECRET=
IBEX_ACCOUNT_ID=
# Optional: per-invoice webhook secret IBEX echoes back for verification.
IBEX_WEBHOOK_SECRET=
# Optional overrides (auto-derived from IBEX_ENV otherwise):
# IBEX_API_URL=https://ibexhub-api.sandbox.poweredbyibex.io
# IBEX_AUTH_URL=https://auth.hub.sandbox.poweredbyibex.io/oauth/token
# IBEX_AUDIENCE=https://api-sandbox.poweredbyibex.io

# --- PawaPay (Mobile Money payout + recipient name lookup / trust layer) ---
PAWAPAY_API_URL=https://api.pawapay.io
PAWAPAY_API_KEY=
PAWAPAY_WEBHOOK_SECRET=

# --- Peexit (SECOND Mobile Money payout aggregator; routing alternative to PawaPay) ---
PEEXIT_API_URL=https://api.peexit.io
PEEXIT_API_KEY=
PEEXIT_WEBHOOK_SECRET=

# --- Peex (OPTIONAL intelligence/verification layer; never in the payment path) ---
PEEX_MODE=sandbox   # off | sandbox | live
PEEX_BASE_URL=https://api.peex.example
PEEX_API_KEY=
PEEX_WEBHOOK_SECRET=peex_whsec_sandbox

# Durable state (node:sqlite). Default data/momome.db; ":memory:" for ephemeral.
DB_PATH=data/momome.db
