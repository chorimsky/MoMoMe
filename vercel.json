{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @momome/app build",
  "outputDirectory": "app/dist",
  "build": {
    "env": {
      "VITE_API_BASE": "https://momome-api-production.up.railway.app/api"
    }
  },
  "rewrites": [
    { "source": "/send", "destination": "/index.html" },
    { "source": "/claim", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/ops", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" }
  ],
  "headers": [
    { "source": "/sitemap.xml", "headers": [{ "key": "Content-Type", "value": "application/xml" }] },
    { "source": "/llms.txt", "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }] },
    { "source": "/ai.txt", "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }] },
    { "source": "/og.svg", "headers": [{ "key": "Content-Type", "value": "image/svg+xml" }] }
  ]
}
