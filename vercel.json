{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @momome/server build && pnpm --filter @momome/app build",
  "outputDirectory": "app/dist",
  "functions": {
    "api/index.ts": { "maxDuration": 30 }
  },
  "env": {
    "DB_PATH": ":memory:"
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/webhooks/(.*)", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/((?!assets/|favicon|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ]
}
