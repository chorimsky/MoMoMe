# ============================================================
# MoMo›Me — Hostinger (Apache/LiteSpeed) static SPA config.
# Lives in public_html (Vite copies it from app/public/ into dist/).
# ============================================================

RewriteEngine On

# --- Force HTTPS ---
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Lightning Address / LNURL: these are BACKEND routes, not part of the SPA.
#     Apache shared/cloud hosting usually disallows mod_proxy (ProxyPass), so we
#     302-redirect to the API host; LNURL (LUD-16) clients follow redirects.
#     If your plan allows ProxyPass, prefer a real reverse proxy instead.
RewriteRule ^\.well-known/lnurlp/(.*)$ https://api.momome.xyz/.well-known/lnurlp/$1 [L,R=302]
RewriteRule ^lnurl/pay/(.*)$ https://api.momome.xyz/lnurl/pay/$1 [L,R=302]

# --- SPA fallback: serve index.html for client-side routes, but never for a
#     real file or directory (so /assets/*, /og/*, the generated SEO HTML, and
#     sitemap.xml etc. are served directly). ---
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# --- Security headers (mirror the prior Vercel config) ---
<IfModule mod_headers.c>
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
  Header always set Content-Security-Policy "frame-ancestors 'none'; object-src 'none'; base-uri 'self'"

  # Hashed build assets are immutable; HTML must revalidate so deploys show up.
  <FilesMatch "\.(js|css|woff2?|ttf|png|jpe?g|webp|gif|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|txt|xml)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# --- Correct content types for the generated SEO/discovery files ---
<IfModule mod_mime.c>
  AddType application/xml .xml
  AddType text/plain .txt
  AddType image/svg+xml .svg
  AddCharset utf-8 .txt .xml
</IfModule>

# --- Compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/plain application/xml
</IfModule>

# --- Custom 404 → SPA (handled by the fallback above; this is a safety net) ---
ErrorDocument 404 /index.html
