# Rails: "sandbox" (default, zero credentials) or "live"
RAILS_MODE=sandbox
PORT=4000
# Public URL the rail providers can reach for webhook callbacks
PUBLIC_URL=http://localhost:4000

# --- IBEX — single inbound provider for Lightning, on-chain BTC, AND USDT ---
# Required when RAILS_MODE=live. One auth + webhook contract covers all three.
IBEX_API_URL=https://api.ibexmercado.com
IBEX_REFRESH_TOKEN=
IBEX_ACCOUNT_ID=
IBEX_WEBHOOK_SECRET=

# --- PawaPay (Mobile Money payout + recipient name lookup / trust layer) ---
PAWAPAY_API_URL=https://api.pawapay.io
PAWAPAY_API_KEY=
PAWAPAY_WEBHOOK_SECRET=

# --- Peexit (SECOND Mobile Money payout aggregator; routing alternative to PawaPay) ---
PEEXIT_API_URL=https://api.peexit.io
PEEXIT_API_KEY=
PEEXIT_WEBHOOK_SECRET=

# --- Peex (OPTIONAL intelligence/verification layer; never in the payment path) ---
PEEX_MODE=sandbox   # off | sandbox | live
PEEX_BASE_URL=https://api.peex.example
PEEX_API_KEY=
PEEX_WEBHOOK_SECRET=peex_whsec_sandbox

# Durable state (node:sqlite). Default data/momome.db; ":memory:" for ephemeral.
DB_PATH=data/momome.db
